local DataStoreService = game:GetService("DataStoreService")
local Players = game:GetService("Players")

local dataStore = DataStoreService:GetDataStore("PlayerData")

local function loadData(player)
    local data
    local success, err = pcall(function()
        data = dataStore:GetAsync(player.UserId)
    end)

    if not success or not data then
        data = {
            weapon = "Rifle",
            fov = 70,
            sensitivity = 0.2
        }
    end

    return data
end

local function saveData(player, data)
    pcall(function()
        dataStore:SetAsync(player.UserId, data)
    end)
end

Players.PlayerAdded:Connect(function(player)
    local data = loadData(player)

    player:SetAttribute("Weapon", data.weapon)
    player:SetAttribute("FOV", data.fov)
    player:SetAttribute("Sensitivity", data.sensitivity)
end)

Players.PlayerRemoving:Connect(function(player)
    local data = {
        weapon = player:GetAttribute("Weapon"),
        fov = player:GetAttribute("FOV"),
        sensitivity = player:GetAttribute("Sensitivity")
    }

    saveData(player, data)
end)

local menu = script.Parent
local pages = menu.Pages

local main = pages.MainFrame
local loadout = pages.LoadoutFrame
local settings = pages.SettingsFrame

local TweenService = game:GetService("TweenService")
local player = game.Players.LocalPlayer
local camera = workspace.CurrentCamera

local hover = menu.Sounds.Hover
local click = menu.Sounds.Click

-- =========================
-- ANIMATIONS
-- =========================
local function show(frame)
    for _,f in pairs(pages:GetChildren()) do
        if f:IsA("Frame") then
            f.Visible = false
        end
    end

    frame.Position = UDim2.new(0.5,0,1.2,0)
    frame.Visible = true

    TweenService:Create(frame, TweenInfo.new(0.35), {
        Position = UDim2.new(0.5,0,0.5,0)
    }):Play()
end

-- =========================
-- BUTTON EFFECTS
-- =========================
local function setup(btn)
    btn.MouseEnter:Connect(function()
        hover:Play()
        TweenService:Create(btn, TweenInfo.new(0.1), {
            BackgroundColor3 = Color3.fromRGB(60,120,255)
        }):Play()
    end)

    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {
            BackgroundColor3 = Color3.fromRGB(40,80,200)
        }):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        click:Play()
    end)
end

-- Apply to all buttons
for _,btn in pairs(menu:GetDescendants()) do
    if btn:IsA("TextButton") then
        setup(btn)
    end
end

-- =========================
-- MAIN NAVIGATION
-- =========================
main.StartButton.MouseButton1Click:Connect(function()
    menu.Enabled = false
    workspace.CurrentCamera.FieldOfView = player:GetAttribute("FOV") or 70
end)

main.LoadoutButton.MouseButton1Click:Connect(function()
    show(loadout)
end)

main.SettingsButton.MouseButton1Click:Connect(function()
    show(settings)
end)

-- =========================
-- LOADOUT
-- =========================
loadout.RifleButton.MouseButton1Click:Connect(function()
    player:SetAttribute("Weapon", "Rifle")
end)

loadout.SMGButton.MouseButton1Click:Connect(function()
    player:SetAttribute("Weapon", "SMG")
end)

loadout.BackButton.MouseButton1Click:Connect(function()
    show(main)
end)

-- Give weapon
