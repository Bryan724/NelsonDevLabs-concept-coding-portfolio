local menu = script.Parent
local pages = menu.Pages

local main = pages.MainFrame
local loadout = pages.LoadoutFrame
local settings = pages.SettingsFrame

local TweenService = game:GetService("TweenService")
local player = game.Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Sounds
local hoverSound = menu.Sounds.Hover
local clickSound = menu.Sounds.Click

-- SETTINGS
local sensitivity = 0.2

-- =========================
-- ANIMATION FUNCTION
-- =========================
local function showFrame(frame)
    for _,f in pairs(pages:GetChildren()) do
        if f:IsA("Frame") then
            f.Visible = false
        end
    end

    frame.Position = UDim2.new(0.5,0,1.2,0)
    frame.Visible = true

    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {
        Position = UDim2.new(0.5,0,0.5,0)
    }):Play()
end

-- =========================
-- BUTTON SETUP FUNCTION
-- =========================
local function setupButton(btn)
    btn.MouseEnter:Connect(function()
        hoverSound:Play()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(60,120,255)
        }):Play()
    end)

    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(40,80,200)
        }):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        clickSound:Play()
    end)
end

-- =========================
-- MAIN BUTTONS
-- =========================
local mainButtons = {
    main.StartButton,
    main.LoadoutButton,
    main.SettingsButton
}

for _,btn in pairs(mainButtons) do
    setupButton(btn)
end

-- Navigation
main.StartButton.MouseButton1Click:Connect(function()
    menu.Enabled = false
end)

main.LoadoutButton.MouseButton1Click:Connect(function()
    showFrame(loadout)
end)

main.SettingsButton.MouseButton1Click:Connect(function()
    showFrame(settings)
end)

